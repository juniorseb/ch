# Copie ce fichier en .env.local et remplis les valeurs au fur et à mesure.
# Tant que VITE_SUPABASE_URL est vide, l'app tourne en mode démo (simulation
# locale, sans aucun appel réseau réel).

# Supabase (Settings -> API dans ton dashboard)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Les autres clés (GeniusPay, ApiPass, Groq, Resend) ne vivent jamais ici --
# elles se configurent comme secrets des Edge Functions (Dashboard ->
# Edge Functions -> Secrets), jamais côté navigateur. Voir le README.
